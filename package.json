{
  "name": "tracer",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:up": "docker compose -f packages/db/docker-compose.yml up -d",
    "db:down": "docker compose -f packages/db/docker-compose.yml down",
    "db:generate": "pnpm --filter @tracer/db generate",
    "db:seed": "pnpm --filter @tracer/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
