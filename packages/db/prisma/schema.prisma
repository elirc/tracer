// Prisma schema for Tracer.
// Sprint 01 introduces a single reference entity — Workspace — to prove the DB → API → UI slice.
// The rich domain (teams, issues, the mutation log) arrives in later sprints.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
}
