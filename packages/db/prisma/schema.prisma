// Prisma schema for Tracer.
// S01: Workspace. S02: identity + membership. S03: the issue domain (issues, workflow states,
// labels) — deliberately a "classic" REST-shaped model. The mutation log that powers real-time
// sync arrives in S06 (see ADR-0002).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
  GUEST
}

// The *type* is the stable API of a workflow state; the name is a per-team label. Queries key
// on type (e.g. "started") so they survive teams renaming their columns.
enum StateType {
  BACKLOG
  UNSTARTED
  STARTED
  DONE
  CANCELED
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatarUrl      String?
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())

  memberships    Membership[]
  sessions       Session[]
  assignedIssues Issue[]

  @@unique([provider, providerUserId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Monotonic per-workspace mutation sequence — the spine of the sync engine (S06).
  mutationSeq Int    @default(0)
  createdAt DateTime @default(now())

  teams       Team[]
  memberships Membership[]
  invites     Invite[]
  mutations   MutationLog[]
}

// Every issue-domain write is recorded here as a sequenced fact. Clients bootstrap by asking for
// everything since their lastSeq, then receive new rows live. "The log is truth; pub/sub is a hint."
model MutationLog {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  seq         Int
  clientId    String?
  mutationId  String?
  entity      String // e.g. "issue"
  entityId    String
  op          String // "create" | "update" | "delete"
  // teamId lets a per-team channel filter deltas (S13 fixes flaw #4 using this).
  teamId      String?
  patch       Json
  createdAt   DateTime @default(now())

  @@unique([workspaceId, seq])
  // Dedupe key for exactly-once-in-effect (S07). mutationId is nullable, and Postgres treats NULLs
  // as distinct, so legacy null rows coexist while client-generated ids are enforced unique.
  @@unique([workspaceId, mutationId])
  @@index([workspaceId, seq])
}

model Team {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  key         String // identifier prefix, e.g. "ENG"
  // Monotonic per-team counter for issue numbers. Incremented atomically (see routes/issues.ts).
  issueCounter Int     @default(0)
  createdAt   DateTime @default(now())

  workflowStates WorkflowState[]
  labels         Label[]
  issues         Issue[]

  @@unique([workspaceId, key])
}

model Membership {
  id           String   @id @default(cuid())
  userId       String
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role         Role     @default(MEMBER)
  guestTeamIds String[]
  createdAt    DateTime @default(now())

  @@unique([userId, workspaceId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Invite {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        Role     @default(MEMBER)
  tokenHash   String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())
}

model WorkflowState {
  id        String    @id @default(cuid())
  teamId    String
  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  type      StateType
  position  Int
  color     String    @default("#8b93a1")
  createdAt DateTime  @default(now())

  issues Issue[]

  @@unique([teamId, name])
}

model Label {
  id     String @id @default(cuid())
  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name   String
  color  String @default("#7c5cff")

  issues IssueLabel[]

  @@unique([teamId, name])
}

model Issue {
  id          String   @id @default(cuid())
  teamId      String
  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  number      Int // per-team; the identifier is team.key + "-" + number (e.g. ENG-123)
  title       String
  description String   @default("")
  stateId     String
  state       WorkflowState @relation(fields: [stateId], references: [id])
  priority    Priority @default(NONE)
  assigneeId  String?
  assignee    User? @relation(fields: [assigneeId], references: [id])
  // Fractional-index key for board/list ordering (S04). A move is a single-row update.
  sortOrder   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // soft delete — every read must filter this out

  labels IssueLabel[]

  @@unique([teamId, number])
  @@index([teamId, stateId, sortOrder])
  @@index([teamId, assigneeId])
}

model IssueLabel {
  issueId String
  labelId String
  issue   Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}
